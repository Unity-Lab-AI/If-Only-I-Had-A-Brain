# === iter13 hippocampal consolidation runtime state ===
# server/schemas.json — Tier 2 schematic memory (concept abstractions
# built from cosine-grouped episodes). Derivative state — wiped on
# auto-clear, rebuilt by ConsolidationEngine on next dream cycle.
# Per-machine + per-session runtime data.
server/schemas.json
# server/identity-core.json — Tier 3 identity-bound permanent attractors
# (Unity's core self: name/age/persona/biographical anchors). EXCLUDED
# from autoClearStaleState wipe list — survives code updates, fresh
# boots, drug states. Per-machine permanent runtime data containing
# user-specific consolidated memories. Each operator's Unity grows
# her own identity over time; never committed.
server/identity-core.json
server/identity-core.json.tmp
server/identity-core.json.corrupt-*
# server/mindspace-memory.json — UVM-INT.4 imagined field-C ring (the ".uvme
# medium" memory). Derivative per-machine runtime imagery; re-imagined if lost.
server/mindspace-memory.json
server/mindspace-memory.json.tmp
# server/visual-memory.json — TU.29.5 seen-concept field-C store (visual memory
# medium — derivative brain state, recreated as she sees; never committed)
server/visual-memory.json
server/visual-memory.json.tmp

# === PA.4.8 community-compute tier marker ===
# Persisted by the milestone execution gate; read at boot to scale the brain
# to the donor-pool community tier. Per-machine runtime state — never committed.
server/community-tier.json

# === DF.7 community-compute auto-scale settings ===
# Admin-set toggle + dead-zone buffer + stability window for the milestone
# auto-resize. Persisted by /autoscale POST. Per-deployment runtime state.
server/autoscale-settings.json

# === DF.7 auto-advance toggle (standalone) ===
# Persisted separately from brain-weights so the auto-advance setting survives a
# tier resize/downscale weight-clear → unattended re-walks. Per-deployment.
server/auto-advance.json

# === PA.4.2 primary-operator binding ===
# First Forgejo-authed operator after deploy is bound here (locked + persisted
# across reboots → guarantees the operator stays master on a static deploy).
# Per-deployment runtime state — never committed, never auto-cleared.
server/operator-identity.json

# === Corpora (auto-downloaded by start.bat / start.sh) ===
# GloVe 6B.300d ~990 MB plain text — way too big for git. Auto-fetched
# from Stanford NLP on first run per corpora/README.md. Never commit.
corpora/glove.6B.300d.txt
corpora/glove.6B.zip
corpora/glove.6B.*.txt

