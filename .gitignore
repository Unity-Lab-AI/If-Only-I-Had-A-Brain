# === Build output ===
dist/
build/
out/
.next/
.nuxt/
.output/
# js/app.bundle.js intentionally NOT ignored — GitHub Pages does not run
# `npm run build`, so the bundle must be checked in so visitors get a
# working landing page instead of a 404 on the main script. `start.bat`
# rebuilds the bundle via `cd server && npm run build` before launching
# the server; Gee's commits should include the fresh bundle whenever
# source files under `js/` change.

# === Donor-app build binaries ===
# Compiled donor executables (cargo --release). Distributed via Forgejo
# releases + the site download links, never committed — way too big for git
# and rebuilt per platform. Stray local build/test copies land in repo root.
unity-donor-*-x86_64*
unity-donor-*.exe
donor-app/target/

# Claude task scheduler runtime lock (session-specific PID)
.claude/scheduled_tasks.lock

# #38/#39 runtime state markers (per-boot, never committed)
server/.resume-marker.json
server/.force-fresh

# runtime state (written by the brain at boot/run — never commit)
server/.last-boot-reason.json
server/resource-config.json
server/auto-advance.json
