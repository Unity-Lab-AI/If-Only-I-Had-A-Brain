{
  "name": "unity-brain-server",
  "version": "1.2.0",
  "private": true,
  "description": "Unity's brain — always on, shared by everyone",
  "main": "brain-server.js",
  "scripts": {
    "start": "node brain-server.js",
    "build": "esbuild ../js/app.js --bundle --format=esm --outfile=../js/app.bundle.js --platform=browser --target=esnext --external:./env.js && npm run build:voiceworker",
    "build:voiceworker": "esbuild ../js/io/voice-piper-worker.js --bundle --format=esm --outfile=../js/voice-piper-worker.bundle.js --platform=browser --target=esnext --alias:fs=../js/io/vendor/node-empty-stub.cjs --alias:path=../js/io/vendor/node-empty-stub.cjs --alias:crypto=../js/io/vendor/node-empty-stub.cjs"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "jpeg-js": "^0.4.4",
    "node-fetch": "^3.3.2",
    "pngjs": "^7.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "esbuild": "^0.21.5"
  }
}
